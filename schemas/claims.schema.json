{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "claims",
  "type": "object",
  "required": ["claims"],
  "properties": {
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "text", "status"],
        "properties": {
          "claim_id": { "type": "string" },
          "text": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["supported", "inconclusive", "contradicted", "rejected", "draft"]
          },
          "evidence": { "type": "object" },
          "limitations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "allowed_in_paper_sections": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

