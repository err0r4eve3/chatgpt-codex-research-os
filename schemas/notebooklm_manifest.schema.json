{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "notebooklm_manifest",
  "type": "object",
  "required": [
    "notebook",
    "interface_policy",
    "imported_sources",
    "export_policy",
    "sync_policy",
    "allowed_uses",
    "prohibited_uses"
  ],
  "properties": {
    "notebook": {
      "type": "object",
      "required": ["id", "title", "cli_alias"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "profile": { "type": "string" },
        "cli_alias": { "type": "string" }
      },
      "additionalProperties": true
    },
    "interface_policy": {
      "type": "object",
      "required": ["preferred_for_cli", "preferred_for_mcp"],
      "additionalProperties": true
    },
    "imported_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "notebooklm_source_id",
          "source_id",
          "source_type",
          "import_type",
          "import_status",
          "citation_status",
          "rights_status"
        ],
        "properties": {
          "notebooklm_source_id": { "type": "string" },
          "source_id": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": [
              "paper",
              "official_repo",
              "benchmark_doc",
              "dataset_doc",
              "official_doc",
              "web_url",
              "youtube",
              "google_drive",
              "local_file",
              "human_note",
              "other"
            ]
          },
          "import_type": {
            "type": "string",
            "enum": ["url", "drive", "text", "file", "youtube", "audio", "other"]
          },
          "import_status": {
            "type": "string",
            "enum": ["pending", "imported", "stale", "removed", "failed"]
          },
          "citation_status": {
            "type": "string",
            "enum": ["unverified", "verified", "rejected"]
          },
          "rights_status": {
            "type": "string",
            "enum": ["unknown", "permitted", "restricted", "public", "internal_only"]
          },
          "export_paths": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "export_policy": {
      "type": "object",
      "required": ["directory", "index"],
      "additionalProperties": true
    },
    "sync_policy": {
      "type": "object",
      "required": ["record_every_import", "verify_before_claims"],
      "additionalProperties": true
    },
    "allowed_uses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prohibited_uses": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}

